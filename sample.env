# App
PORT=3000

# CORS
CORS_WHITELIST_REGEXP=^https?://(?:.+?\.)?(?:lido|testnet|mainnet)\.fi$

# The number of seconds that each request will last in storage
GLOBAL_THROTTLE_TTL=5

# The maximum number of requests within the TTL limit
GLOBAL_THROTTLE_LIMIT=100

# Cache expiration time in seconds
GLOBAL_CACHE_TTL=1

# Sentry DSN
SENTRY_DSN=

# Log level: debug, info, notice, warning or error
LOG_LEVEL=debug

# Log format: simple or json
LOG_FORMAT=json

# Override Devnet contacts, naming like JSON file, example: network.example (network-configs/network.example.json)
CUSTOM_NETWORK_FILE_NAME=

# Everything below for LSV CLI (temporarily)
SKIP_LSV_CLI_CHECK_CONFIG=true

# CL URL with "/" at the end
CL_URL=
