# App
PORT=3000
WORKER_PORT=3001

# CORS
CORS_WHITELIST_REGEXP=^https?://(?:.+?\.)?(?:lido|testnet|mainnet)\.fi$

# The number of seconds that each request will last in storage
GLOBAL_THROTTLE_TTL=5

# The maximum number of requests within the TTL limit
GLOBAL_THROTTLE_LIMIT=100

# Cache expiration time in seconds
GLOBAL_CACHE_TTL=120

# Sentry DSN
SENTRY_DSN=

# Log level: debug, info, notice, warning or error
LOG_LEVEL=debug

# Log format: simple or json
LOG_FORMAT=json

# postgres configurations
POSTGRES_HOST=127.0.0.1

POSTGRES_PORT=5432

POSTGRES_USER=postgres

POSTGRES_PASSWORD=postgres

POSTGRES_DATABASE=vault-api

# CHAIN_ID
CHAIN_ID=560048

# Add and/or override Devnet contacts, naming like JSON file, example: network.example (network-configs/network.example.json)
CUSTOM_NETWORK_FILE_NAME=hoodi

# EL RPC URLs delimeted by commas, first entry is primary, else are fallbacks
EL_RPC_URLS=

# CL URLs delimeted by commas, first entry is primary, else are fallbacks
CL_API_URLS=

# IPFS gateways delimeted by commas, first entry is primary, else are fallbacks
IPFS_GATEWAYS=https://ipfs.io/ipfs

# START_REPORT_BLOCK_NUMBER defines the block number from which to start loading or processing reports
# Set to empty, zero or negative value to fetch only the last 2 reports!
START_REPORT_BLOCK_NUMBER=1332510

# MINIMAL_VAULTS_FETCHING_MODE_COUNT defines the maximum number of vaults to fetch in "minimal fetching mode"
# Leave empty or set to 0 to fetch all vaults
# Set to any value > 0 to run in minimal vaults fetching mode and limit vault fetching to this number
MINIMAL_VAULTS_FETCHING_MODE_COUNT=

# Maximum number of CachedTree entries to store in LRU cache (each entry includes MerkleTree and auxiliary data)
REPORT_MERKLE_TREE_CACHE_MAX=5

VAULTS_BATCH_SIZE=50
# every hour at **:00 UTC
VAULTS_CRON=0 * * * *

VAULT_MEMBERS_BATCH_SIZE=10
# once per day at 00:02 UTC
VAULT_MEMBERS_CRON=2 0 * * *

REPORT_BATCH_SIZE=100
# every hour at **:04 UTC
REPORT_CRON=4 * * * *

# Max number of vault metrics calculations processed in parallel.
# Helps control load on RPC providers and database.
REPORT_METRICS_PROCESSING_CONCURRENCY=20

# Start metrics calculation from a specific report CID on cold startup
COLD_STARTUP_REPORTS_FROM_CID=QmNYqrnDoPxJNEiKGuLFbTS7gvCJvXVLhydqKXkVJfn9Fx
