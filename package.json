{
  "name": "lido-vaults-api",
  "version": "0.0.1",
  "description": "Lido Vaults API",
  "author": "Lido team",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "yarn typeorm:migration:run && node dist/main",
    "start:worker": "node dist/worker-entry.js",
    "start:worker:dev": "ts-node -r tsconfig-paths/register src/worker-entry.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "typeorm:migration:create": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:create",
    "typeorm:migration:generate": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate -d src/db/config.ts",
    "typeorm:migration:run": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d ./dist/db/config",
    "typeorm:schema:drop": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js schema:drop"
  },
  "dependencies": {
    "@ethersproject/address": "^5.8.0",
    "@ethersproject/providers": "^5.8.0",
    "@fastify/static": "6.12.0",
    "@lido-nestjs/contracts": "^9.8.0",
    "@lido-nestjs/execution": "^1.9.3",
    "@lido-nestjs/logger": "^1.0.1",
    "@lidofinance/lsv-cli": "1.4.0",
    "@lidofinance/rpc": "^0.52.0",
    "@lidofinance/satanizer": "^0.32.0",
    "@nestjs/cache-manager": "^2.2.2",
    "@nestjs/common": "10.4.22",
    "@nestjs/config": "^2.2.0",
    "@nestjs/core": "10.4.22",
    "@nestjs/platform-fastify": "10.4.22",
    "@nestjs/schedule": "^2.2.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/terminus": "^9.1.4",
    "@nestjs/throttler": "^6.0.0",
    "@nestjs/typeorm": "^10.0.2",
    "@openzeppelin/merkle-tree": "^1.0.8",
    "@sentry/node": "^7.29.0",
    "@willsoto/nestjs-prometheus": "^5.1.0",
    "cache-manager": "^5.2.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cron": "^4.3.0",
    "cron-parser": "^5.2.0",
    "ethers": "5.8.0",
    "fastify-swagger": "^5.2.0",
    "lodash.chunk": "^4.2.0",
    "lru-cache": "^11.1.0",
    "pg": "^8.16.0",
    "prom-client": "^14.1.1",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^3.0.2",
    "rxjs": "^7.5.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "9.5.0",
    "@nestjs/schematics": "^9.0.4",
    "@nestjs/testing": "^9.2.1",
    "@types/cache-manager": "^4.0.2",
    "@types/jest": "^29.2.5",
    "@types/lodash.chunk": "^4.2.9",
    "@types/node": "^18.11.18",
    "@types/supertest": "^2.0.11",
    "@typescript-eslint/eslint-plugin": "^5.48.1",
    "@typescript-eslint/parser": "^5.48.1",
    "eslint": "^8.31.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-prettier": "^4.0.0",
    "jest": "^29.3.1",
    "prettier": "^2.8.2",
    "supertest": "^6.2.1",
    "ts-jest": "^29.0.3",
    "ts-loader": "^9.2.6",
    "ts-node": "^10.4.0",
    "tsconfig-paths": "^4.1.2",
    "typescript": "^5.7.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
